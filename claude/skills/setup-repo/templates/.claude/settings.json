{
  "$schema": "https://code.claude.com/schemas/settings.json",
  "permissions": {
    "deny": [
      "rm -rf",
      "chmod 777",
      "eval",
      "> /dev/sda",
      "mkfs",
      "dd if=",
      ":(){ :|:& };:"
    ],
    "allow": [
      "git status",
      "git log",
      "git diff",
      "git show",
      "git branch"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/block-dangerous-git.sh"
          }
        ]
      }
    ]
  }
}
