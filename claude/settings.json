{
  "permissions": {
    "allow": [
      "Bash(wc:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(chmod 777 *)",
      "Bash(eval *)",
      "Bash(base64 -d *)",
      "Bash(python -c *)",
      "Bash(node -e *)",
      "Bash(ruby -e *)",
      "Bash(perl -e *)",
      "Bash(drop table *)",
      "Bash(DROP TABLE *)"
    ],
    "defaultMode": "plan"
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/dotfiles/scripts/claude-notify.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "$HOME/dotfiles/scripts/claude-statusline.sh"
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  }
}
